{
  "name": "cablesnap",
  "version": "0.26.19",
  "license": "AGPL-3.0-or-later",
  "main": "expo-router/entry",
  "scripts": {
    "changelog:gen": "tsx scripts/generate-changelog.ts",
    "prestart": "npm run changelog:gen",
    "start": "expo start",
    "preandroid": "npm run changelog:gen",
    "android": "expo start --android",
    "preios": "npm run changelog:gen",
    "ios": "expo start --ios",
    "preweb": "npm run changelog:gen",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "cross-env NODE_ENV=test jest",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:design": "playwright test e2e/design-quality.spec.ts e2e/chip-layout.spec.ts",
    "test:maestro": "maestro test .maestro/flows/",
    "test:maestro:record": "maestro record",
    "prebuild:apk": "npm run changelog:gen",
    "build:apk": "eas build -p android --profile preview --local",
    "prebuild:apk:prod": "npm run changelog:gen",
    "build:apk:prod": "eas build -p android --profile production --local",
    "prebuild:apk:cloud": "npm run changelog:gen",
    "build:apk:cloud": "eas build -p android --profile preview",
    "install:apk": "adb install -r $(ls -t *.apk | head -1)",
    "fta": "fta-cli app lib components hooks --json",
    "generate:exercise-images": "tsx scripts/generate-exercise-images.ts",
    "screenshots:raw": "playwright test e2e/screenshot-capture.spec.ts --project=store-pixel9 --project=store-fold7",
    "screenshots:frame": "tsx scripts/generate-store-screenshots.ts",
    "screenshots": "npm run screenshots:raw && npm run screenshots:frame",
    "prepare": "husky || true",
    "postinstall": "npx --no-install patch-package && node scripts/skia-setup.js"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.9",
    "@quidone/react-native-wheel-picker": "^1.6.4",
    "@react-native-community/netinfo": "11.5.2",
    "@sentry/react-native": "^8.9.2",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.99.2",
    "drizzle-orm": "^0.45.2",
    "expo": "~55.0.15",
    "expo-audio": "~55.0.14",
    "expo-auth-session": "~55.0.14",
    "expo-blur": "~55.0.14",
    "expo-build-properties": "^55.0.13",
    "expo-camera": "~55.0.15",
    "expo-constants": "~55.0.14",
    "expo-crypto": "~55.0.14",
    "expo-dev-client": "~55.0.27",
    "expo-device": "~55.0.15",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.16",
    "expo-haptics": "~55.0.14",
    "expo-health-connect": "^0.1.1",
    "expo-image": "~55.0.8",
    "expo-image-manipulator": "~55.0.15",
    "expo-image-picker": "~55.0.18",
    "expo-keep-awake": "~55.0.6",
    "expo-linking": "~55.0.13",
    "expo-local-authentication": "~55.0.13",
    "expo-localization": "~55.0.13",
    "expo-modules-core": "~55.0.22",
    "expo-notifications": "~55.0.19",
    "expo-router": "~55.0.12",
    "expo-secure-store": "~55.0.13",
    "expo-sharing": "~55.0.18",
    "expo-splash-screen": "~55.0.18",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.15",
    "expo-web-browser": "~55.0.14",
    "lucide-react-native": "^1.8.0",
    "papaparse": "^5.5.3",
    "patch-package": "^8.0.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.72.1",
    "react-native": "0.83.4",
    "react-native-body-highlighter": "^3.2.0",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-health-connect": "^3.5.0",
    "react-native-reanimated": "4.3.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.8.1",
    "victory-native": "^41.20.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/papaparse": "^5.5.2",
    "@types/react": "~19.2.10",
    "@types/sharp": "^0.32.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "fta-cli": "^3.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.16",
    "lint-staged": "^16.4.0",
    "react-test-renderer": "19.2.0",
    "sharp": "^0.34.5",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "wait-on": "^9.0.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0"
    ]
  },
  "private": true,
  "optionalDependencies": {
    "@shopify/react-native-skia": "2.6.2"
  }
}
