#!/bin/sh

# ─── License Integrity Gate ──────────────────────────────────────
# Blocks push if LICENSE file has been tampered with
if [ -f "scripts/check-license.sh" ]; then
  echo "📜 Checking license integrity..."
  if ! ./scripts/check-license.sh --quick; then
    echo ""
    echo "LICENSE file must not be modified. Restore it: git checkout origin/main -- LICENSE"
    exit 1
  fi
fi

# ─── Exercise Illustration Bundle Gate (BLD-561) ────────────────
# Blocks push if assets/exercise-illustrations/**/*.webp exceeds the hard-fail
# bundle budget (R2 plan: target ≤8MB, hard fail >12MB).
if [ -f "scripts/verify-exercise-illustrations-size.sh" ]; then
  echo "🖼️  Verifying exercise illustration bundle size..."
  if ! ./scripts/verify-exercise-illustrations-size.sh; then
    echo ""
    echo "Exercise illustration assets exceeded the hard-fail bundle budget."
    exit 1
  fi
fi

# ─── Curation Gate (BLD-743 — CEO Option A, comment 90c5899b) ──
# Blocks push if any pilot exercise has a sign-off block in CURATION.md
# whose `gateBlocks(verdict, safetyClass)` returns true (REJECT,
# NEEDS_RESEARCH, UNKNOWN, or APPROVE_WITH_CHANGES classified SAFETY by
# the deterministic discriminator). Single source of truth for the gate
# logic is `scripts/curate-exercise-images.ts`; this hook calls
# `scripts/check-curation-gate.ts` which imports the same function.
if [ -f "scripts/check-curation-gate.ts" ] && [ -f "assets/exercise-illustrations/CURATION.md" ]; then
  echo "🩺 Verifying exercise curation gate (BLD-743)..."
  if ! npx tsx scripts/check-curation-gate.ts; then
    echo ""
    echo "Curation gate BLOCKED push. Address findings in CURATION.md and re-run:"
    echo "  OPENAI_API_KEY=… PERPLEXITY_API_KEY=… npx tsx scripts/curate-exercise-images.ts"
    echo "To skip this check (governance escape hatch only): git push --no-verify"
    exit 1
  fi
fi

# ─── Test Budget Gate ────────────────────────────────────────────
# Blocks push if test count exceeds budget (1800 test cases)
# Scopes duplicate/overlap checks to changed test files only (BLD-812)
if [ -f "scripts/audit-tests.sh" ]; then
  echo "🧪 Running test audit..."
  remote_branch_for_tests=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || echo "origin/main")
  changed_test_files=$(git diff --name-only "$remote_branch_for_tests"...HEAD -- '__tests__/**/*.ts' '__tests__/**/*.tsx' 2>/dev/null || true)
  if [ -n "$changed_test_files" ]; then
    # shellcheck disable=SC2086
    if ! ./scripts/audit-tests.sh --skip-runtime $changed_test_files 2>/dev/null; then
      echo ""
      echo "Consolidate tests before pushing. Run: ./scripts/audit-tests.sh --detail"
      echo "To skip this check: git push --no-verify"
      exit 1
    fi
  else
    echo "  ✅ No test files changed, skipping test audit"
  fi
fi

# FTA (File Complexity Analysis) pre-push gate
# Blocks push if any changed .ts/.tsx file exceeds the FTA score cap.
# FTA Score: < 50 = OK, 50-60 = Could be better, > 60 = Needs improvement
FTA_SCORE_CAP=70

# Compare HEAD against the remote tracking branch
remote_branch=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || echo "origin/main")

# Get changed .ts/.tsx files (exclude tests, mocks, config files)
changed_files=$(git diff --name-only --diff-filter=ACMR "$remote_branch"...HEAD -- '*.ts' '*.tsx' \
  | grep -v '__tests__/' \
  | grep -v '__mocks__/' \
  | grep -v '\.test\.' \
  | grep -v '\.spec\.' \
  | grep -v 'jest\.' \
  | grep -v 'babel\.config' \
  | grep -v 'metro\.config' \
  | grep -v 'app\.config' \
  || true)

if [ -z "$changed_files" ]; then
  exit 0
fi

# Create temp dir for analysis (avoids shell issues with parentheses in paths)
tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

# Copy files with safe names, write mapping file
mapfile="$tmpdir/_filemap.txt"
: > "$mapfile"
for file in $changed_files; do
  if [ ! -f "$file" ]; then
    continue
  fi
  safe_name=$(echo "$file" | sed 's/[^a-zA-Z0-9._-]/__/g')
  cp "$file" "$tmpdir/$safe_name"
  echo "${safe_name}=${file}" >> "$mapfile"
done

if [ ! -s "$mapfile" ]; then
  exit 0
fi

# Run FTA on all copied files at once
output=$(npx fta-cli "$tmpdir" --json 2>/dev/null || true)

if [ -z "$output" ]; then
  echo "⚠️  FTA: could not analyze files, skipping check"
  exit 0
fi

# Parse JSON results and check for violations
echo "$output" | FTA_SCORE_CAP="$FTA_SCORE_CAP" MAPFILE="$mapfile" node -e "
  const fs = require('fs');
  const data = JSON.parse(fs.readFileSync('/dev/stdin', 'utf8'));
  const mapText = fs.readFileSync(process.env.MAPFILE, 'utf8').trim();
  const fileMap = {};
  mapText.split('\n').forEach(line => {
    const idx = line.indexOf('=');
    if (idx > 0) fileMap[line.slice(0, idx)] = line.slice(idx + 1);
  });
  const cap = Number(process.env.FTA_SCORE_CAP);
  const fails = data.filter(f => f.fta_score > cap);
  if (fails.length > 0) {
    console.log('');
    console.log('🚨 FTA Score Cap Exceeded (limit: ' + cap + ')');
    console.log('─'.repeat(70));
    fails.forEach(f => {
      const basename = f.file_name.split('/').pop();
      const orig = fileMap[basename] || basename;
      console.log('  ' + orig);
      console.log('    Score: ' + f.fta_score.toFixed(1) + ' ' + f.assessment);
      console.log('    Lines: ' + f.line_count + '  Cyclomatic: ' + f.cyclo + '  Halstead Difficulty: ' + f.halstead.difficulty.toFixed(1));
      console.log('');
    });
    console.log('Refactor these files to reduce complexity before pushing.');
    console.log('To skip this check: git push --no-verify');
    console.log('');
    process.exit(1);
  }
"

exit_code=$?
file_count=$(echo "$changed_files" | wc -l | tr -d ' ')
if [ $exit_code -ne 0 ]; then
  exit 1
fi

echo "✅ FTA: $file_count file(s) analyzed, all within score cap ($FTA_SCORE_CAP)"
exit 0
